{
    "layer": "top",
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 24, // Waybar height (to be removed for auto height)
    "spacing": 0, // Gaps between modules (4px)
    
    "modules-left": [
        "hyprland/workspaces",
        "idle_inhibitor"
    ],
    "modules-center": [
        "hyprland/window"

    ],
    
    "modules-right": [
        "tray", 
        //"keyboard-state", 
        "wireplumber", // #98971A
        //"network", 
        "backlight", // #D79921
        "battery", // #458588
        "clock", // $B16286
        "custom/poweroff" // #689D6A
    ],

    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },
   
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "tray": {
        "spacing": 8
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d-%m-%Y | %R}",
        "interval": 60
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["", ""]
    },

    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "🔇 {format_source}",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "custom/poweroff": {
        "format": " ",
        "on-click": "wlogout"
    }
}
