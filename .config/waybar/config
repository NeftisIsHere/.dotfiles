{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 1,
    
    "modules-left": [
        "custom/poweroff",
        "hyprland/workspaces",
        "river/tags"
    ],
    "modules-center": [
        "river/window"
    ],
    
    "modules-right": [
        "tray", 
        "wireplumber", // #98971A
        "backlight", // #D79921
        "battery", // #458588
        "clock", // $B16286
         // #689D6A
        "custom/swaync"
    ],

    "import": [ "$dotconf/waybar/hyprland/modules" ],
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },

    "custom/swaync": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
        "notification": "пВҐ<span foreground='red'><small><sup>вђ§</sup></small></span>",
        "none": "пВҐ",
        "dnd-notification": "пЗЈ<span foreground='red'><small><sup>вђ§</sup></small></span>",
        "dnd-none": "пЗЈ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
    },

    "tray": {
        "spacing": 8
    },

    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["пЖЕ", "пДС"]
    },

    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "рЯФЗ {format_source}",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },
    
    "battery": {
        "bat": "BAT1",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"],
        "max-length": 25
    },    
    "clock": {
        "format": "{:%H:%M} пАЧ ",
        "format-alt": "{:%A, %B %d, %Y (%R)} пАЧ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },

    "custom/poweroff": {
        "format": "пАС ",
        "on-click": "wlogout"
    }
}
