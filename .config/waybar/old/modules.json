{
// ------------------------------------------------------------------- 
// Left Modules
// ------------------------------------------------------------------- 
	"wlr/workspaces": {
		"on-click": "activate",
		"all-outputs": true,
	},

// ------------------------------------------------------------------- 
// Center Modules
// ------------------------------------------------------------------- 
	"hyprland/window": {
		"max-length": 120,
		"rewrite": {
		"^(.*) тАФ (?:Mozilla Firefox|Firefox Developer Edition)( Private Browsing)?$": "$1",
		"^(.*) - Discord$": "$1",
		"^(.*) тАв - Sublime Text$": "$1",
		"^(.*) - Code - OSS$": "$1"
		}
	},

// ------------------------------------------------------------------- 
// Right Modules
// ------------------------------------------------------------------- 
	"idle_inhibitor": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"activated": "яБо",
			"deactivated": "яБ░"
		}
	},
    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon} {volume}% {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-bluetooth": "{icon} {volume}%яКФ",
        "format-bluetooth-muted": "яЪй {icon}яКФ",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

	"backlight": {
		"tooltip": false,
		"device": "intel_backlight",
		"format": "{icon} {percent}%",
		"format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
	},
	
	"network": {
        // "format-wifi": "{essid} ({signalStrength}%)",
        // "format-ethernet": "{ipaddr}/{cidr}",
        "format": "яЗл",
        "format-disconnected": "ґ░Цк",
        "tooltip-format": "{ifname} via {gwaddr}",
    },
	// Battery
    "battery": {
        "states": {
            "good": 85,
            "warning": 40,
            "critical": 30
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
	      "interval": 1
    },

	"clock": {
        "tooltip": false,
        "format": "{:%I:%M:%S %p %d/%m/%y}",
        "interval": 1
    },

	"tray": {
	    "icon-size": 21,
	    "spacing": 10
	}, 

	//WLogout
	"custom/exit": {
		"format": "яАС",
		"on-click": "wlogout",
		"tooltip": false
	}	

}
