alias poweroff='shutdown 0'
alias systemlogs='journalctl -b'

alias ls='eza --icons --almost-all --group-directories-first'
alias la='eza --long --almost-all --header --total-size'


# More color!
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias ip='ip -color=auto'

alias start-docker='sudo systemctl start docker'
